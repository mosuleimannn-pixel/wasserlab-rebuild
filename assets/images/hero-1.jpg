            <style>
    .popup-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.5);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 10000;
    }

    .popup {
        background-color: #fff;
        padding: 20px;
        border-radius: 5px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.25);
        z-index: 10001;
    }

    .close-button {
        background-color: #444;
        color: white;
        border: none;
        padding: 10px 20px;
        margin-top: 20px;
        cursor: pointer;
    }

    .close-button:hover {
        background-color: #666;
    }

    .cookie-notice {
        position: fixed;
        width: 100%;
        height: 100vh;
        background-color: rgba(0,0,0,0.5);
        z-index: 99999999999;
    }

    .cookie-notice-content {
        position: fixed;
        bottom: 50%;
        left: calc(50% - 200px);
        width: 440px;
        background-color: #f8f9fa;
        padding: 20px;
        box-shadow: 0px -2px 5px rgba(0,0,0,0.2);
        z-index: 9999;
        justify-content: space-around;
        align-items: center;
        border-radius: 8px;
    }

    .cookie-notice-content div{
        margin-top: 20px;
        display: flex;
        justify-content: space-between;
    }

    .cookie-notice p {
        margin: 0;
    }

    .cookie-notice button {
        padding: 5px 10px;
    }
</style>

<script>

    function setCookieConsent() {
        document.cookie = "cookieConsent=ok; path=/; max-age=31536000"; // Expira en 1 año
        location.reload();
    }

    function deleteCookie(name) {
        var path = ";path=";
        var domain = ";domain="+ window.location.hostname;

        document.cookie = name + "=; expires=Thu, 01 Jan 1970 00:00:00 GMT" + path + "/";
        document.cookie = name + "=; expires=Thu, 01 Jan 1970 00:00:00 GMT" + path + "/" + domain + window.location.hostname;
    }

    function borrarCookiesQueempiezanPor(startString) {
        var cookies = document.cookie.split(";");

        for (var i = 0; i < cookies.length; i++) {
            var cookie = cookies[i];
            var eqPos = cookie.indexOf("=");
            var name = eqPos > -1 ? cookie.substr(0, eqPos) : cookie.trim();
            name = name.trimStart();

            var domain = window.location.hostname.replace('www', '');
            var domainAttribute = "domain=" + domain + '; ';

            if (name.startsWith(startString)) {
                document.cookie = name + "=; path=/; " + domainAttribute + "expires=Thu, 01 Jan 1970 00:00:00 GMT";
            } else {
                console.log(name);
                console.log(domain);
                console.log(domainAttribute);
            }
        }
    }

    $(function(){
        var checkboxAnalytical = document.querySelector('input[name="analyticalCookies"]');
        var botonAceptarTodas = document.getElementById('accept-all');
        var botonRechazarTodas = document.getElementById('reject-all');
        var configureButton = document.getElementById('configure');
        var botonConfigurarFooter = document.getElementById('configure-cookies-footer');
        var cookieNotice = document.querySelector('.cookie-notice');
        var popupOverlay = document.querySelector('.popup-overlay');
        var closeButton = document.querySelector('.close-button');
        var cookieValue = document.cookie
            .split('; ')
            .find(row => row.startsWith('analyticalCookies'))
            ?.split('=')[1];

        function updateCookie() {
            if (checkboxAnalytical.checked) {
                document.cookie = "analyticalCookies=enabled; path=/; max-age=31536000"; // Expira en 1 año
            } else {
                document.cookie = "analyticalCookies=; path=/; expires=Thu, 01 Jan 1970 00:00:00 GMT";
                borrarCookiesQueempiezanPor('_g');
            }
        }

        if (checkboxAnalytical) {
            checkboxAnalytical.addEventListener('change', function() {
                updateCookie();
            });
        }

        checkboxAnalytical.checked = (cookieValue === 'enabled');

        if(cookieValue !== 'enabled') {
            document.cookie = "_ga_ZLFDT9NR15=; path=/; domain=.wasserlab.com; expires=Thu, 01 Jan 1970 00:00:00 GMT";
        }

        function closePopup() {
            popupOverlay.style.display = 'none';
        }

        if (closeButton) {
            closeButton.addEventListener('click', function() {
                closePopup();
            });
        }

        botonAceptarTodas.addEventListener('click', function() {
            cookieNotice.style.display = 'none';
            var checkboxes = document.querySelectorAll('.formulario-cookies input[type="checkbox"]:not(:disabled)');
            
            checkboxes.forEach(function(checkbox) {
                checkbox.checked = true;
                var event = new Event('change', {
                    'bubbles': true,
                    'cancelable': true
                });
                checkbox.dispatchEvent(event);
            });

            setCookieConsent();
        });

        botonRechazarTodas.addEventListener('click', function() {
            cookieNotice.style.display = 'none';
            var checkboxes = document.querySelectorAll('.formulario-cookies input[type="checkbox"]:not(:disabled)');

            checkboxes.forEach(function(checkbox) {
                checkbox.checked = false;
                var event = new Event('change', {
                    'bubbles': true,
                    'cancelable': true
                });
                checkbox.dispatchEvent(event);
            });

            setCookieConsent();
        });

        configureButton.addEventListener('click', function() {
            popupOverlay.style.display = 'flex';
            cookieNotice.style.display = 'none';
        });

        botonConfigurarFooter.addEventListener('click', function() {
            popupOverlay.style.display = 'flex';
            cookieNotice.style.display = 'none';
        });

        closeButton.addEventListener('click', function() {
            popupOverlay.style.display = 'none';
            cookieNotice.style.display = 'flex';
            setCookieConsent();
        });
    });
</script>

<div class="popup-overlay" style="display: none;">
    <div class="popup">
        <p>Configuración de Cookies</p>
        <p>Selecciona las cookies que quieres activar:</p>

        <form class="formulario-cookies">
            <div class="form-group">
                <label>
                    <input type="checkbox" name="necessaryCookies" checked disabled> Cookies Necesarias
                </label>
                <p>Son las cookies imprescindibles para que la web funcione correctamente.</p>
            </div>
            <div class="form-group">
                <label>
                    <input type="checkbox" name="analyticalCookies"> Cookies Analíticas
                </label>
                <p>Son las cookies que recopilan ciertos datos estadísticos que nos ayudan a mejorar la web.</p>
            </div>
        </form>

        <button class="close-button">Cerrar</button>
    </div>
</div>

<div class="cookie-notice">
    <div class="cookie-notice-content">
        <p style="font-size: 24px;font-weight: bold;">COOKIES</p>
        <p>Este sitio web utiliza <a href="https://www.wasserlab.com/es/politica-de-cookies">cookies</a> propias y de terceros para el correcto funcionamiento y visualización del sitio web por parte del usuario, así como para la recogida de estadísticas</p>
        <p>&nbsp;</p>
        <p>Puede aceptar todas las cookies pulsando el botón "Aceptar todo", rechazar su uso pulsando el botón"Rechazar todo" y configurarlas pulsando en el botón "Configurar".</p>
        <div>
            <button id="accept-all">Aceptar todo</button>
            <button id="reject-all">Rechazar todo</button>
            <button id="configure">Configurar</button>
        </div>
    </div>
</div>

